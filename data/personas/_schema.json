{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://echoclass.dev/schemas/persona.json",
  "title": "EchoClass Student Persona",
  "description": "虚拟学生人设定义。基于皮亚杰认知发展阶段理论设计，用于驱动 1v1 答疑陪练中 StudentAgent 的角色扮演行为。",
  "$comment": "v1.1 (2026-04-25)：移除 4 个死字段（cognitive_stage / interaction_frequency / emotional_tendency / learning_motivation），由 stage.piaget_stage 统一约束认知阶段；family_background 降级为可选。",
  "type": "object",
  "required": [
    "id",
    "name",
    "gender",
    "grade",
    "age",
    "stage_id",
    "subject_level",
    "personality",
    "speech_style",
    "catchphrases",
    "misconception_tendencies",
    "attention_span",
    "behavior_traits",
    "avatar_seed",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "人设唯一标识符 (UUID v4)"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 10,
      "description": "中文姓名"
    },
    "gender": {
      "type": "string",
      "enum": [
        "男",
        "女"
      ],
      "description": "性别"
    },
    "grade": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "J1",
        "J2",
        "J3",
        "H1",
        "H2",
        "H3"
      ],
      "description": "年级。P=小学 (Primary), J=初中 (Junior), H=高中 (High)"
    },
    "age": {
      "type": "integer",
      "minimum": 6,
      "maximum": 18,
      "description": "年龄"
    },
    "stage_id": {
      "type": "string",
      "enum": [
        "p_lower",
        "p_middle",
        "p_upper",
        "j_lower",
        "j_upper",
        "h"
      ],
      "description": "关联的学段 id，对应 data/stage_profiles/*.json"
    },
    "subject_level": {
      "type": "string",
      "enum": [
        "优秀",
        "中等",
        "薄弱"
      ],
      "description": "学科整体水平"
    },
    "personality": {
      "type": "string",
      "minLength": 10,
      "description": "性格特征描述（2-3 句话）"
    },
    "speech_style": {
      "type": "string",
      "minLength": 10,
      "description": "说话风格描述，包括用词习惯、句式偏好等"
    },
    "catchphrases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "description": "典型口头禅，≥3 条"
    },
    "misconception_tendencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "容易产生的迷思概念倾向（与学科相关）"
    },
    "attention_span": {
      "type": "string",
      "enum": [
        "short",
        "medium",
        "long"
      ],
      "description": "注意力持续时间。short=容易走神, medium=一般, long=高度专注"
    },
    "behavior_traits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "课堂行为标签列表，如 ['积极举手', '爱抢答']"
    },
    "family_background": {
      "type": "string",
      "minLength": 10,
      "description": "简要家庭背景描述，可选；当前 prompt 模板未直接消费，作为人设语料补充与未来扩展材料"
    },
    "avatar_seed": {
      "type": "string",
      "description": "头像生成种子字符串（前端 DiceBear 等工具用）"
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 100,
      "description": "一句话人设概括，用于 API 列表展示"
    }
  },
  "additionalProperties": false
}