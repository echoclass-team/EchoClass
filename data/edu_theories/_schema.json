{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://echoclass.dev/schemas/edu_theory.json",
  "title": "EchoClass Educational Theory Card",
  "description": "教育学理论卡片。POC 阶段为 JSON 文件存储；正式版会迁移到 SQLite + Chroma 双存储。每张卡片描述一个经典教育学理论，并按 trait（特征变体）拆分可操作行为准则，供 Persona / Misconception / Rubric 三类对象通过 anchors 引用。",
  "type": "object",
  "required": [
    "id",
    "name_zh",
    "scholar",
    "school",
    "summary",
    "traits",
    "applies_to",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "理论卡片唯一 id（snake_case），全局唯一"
    },
    "name_zh": {
      "type": "string",
      "minLength": 2,
      "description": "理论中文名称"
    },
    "name_en": {
      "type": "string",
      "description": "理论英文名称"
    },
    "scholar": {
      "type": "string",
      "description": "提出者（含姓与提出年份，如 'Albert Bandura (1977)'）"
    },
    "year": {
      "type": "integer",
      "description": "提出年份（便于排序）"
    },
    "school": {
      "type": "string",
      "description": "所属学派/分支（如 '社会认知理论' / '建构主义'）"
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "description": "2-3 句话概括理论核心，给 LLM 看的上下文"
    },
    "traits": {
      "type": "object",
      "description": "理论的特征变体。每个 trait 是该理论下可被锚定的具体类型，含可操作行为准则。",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["label", "operational_rules"],
        "properties": {
          "label": {
            "type": "string",
            "description": "trait 中文标签（出现在 prompt 中）"
          },
          "operational_rules": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" },
            "description": "该 trait 在课堂场景下的可观察行为准则。每条要够具体让 LLM 能在 1v1 答疑中模仿。"
          }
        }
      }
    },
    "applies_to": {
      "type": "object",
      "description": "标记该理论可锚定到哪些对象类型，便于检索与 review",
      "properties": {
        "persona": { "type": "boolean", "default": false },
        "misconception": { "type": "boolean", "default": false },
        "rubric": { "type": "boolean", "default": false }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "权威文献引用（APA 或 GB/T 7714 格式）"
    }
  }
}
