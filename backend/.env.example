# EchoClass backend environment template.
# 复制为 .env 后填入真实值；.env 已在 .gitignore，严禁提交。

# ---------- LLM (OpenAI 兼容接口) ----------
# 默认：华东师范大学 ChatECNU（参赛平台自有大模型）
# 获取 API Key：登录 https://chat.ecnu.edu.cn/html/ → 左下角头像 → 我的令牌
# 文档：https://developer.ecnu.edu.cn/vitepress/llm/authorization.html
OPENAI_API_KEY=your-chatecnu-token-here
OPENAI_BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
LLM_MODEL=ecnu-max

# 也可切其它 OpenAI 兼容后端（取消注释即可）：
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ---------- CORS (逗号分隔) ----------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
